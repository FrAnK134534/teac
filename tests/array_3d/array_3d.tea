use std;

fn main() -> i32
{
    let cube: [[[i32; 4]; 3]; 2];
    let i:i32;
    let j:i32;
    let k:i32;
    let val:i32;

    val = 0;
    i = 0;
    while i < 2
    {
        j = 0;
        while j < 3
        {
            k = 0;
            while k < 4
            {
                cube[i][j][k] = val;
                val = val + 1;
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    let sum:i32;
    sum = 0;
    i = 0;
    while i < 2
    {
        j = 0;
        while j < 3
        {
            k = 0;
            while k < 4
            {
                let v:i32;
                v = cube[i][j][k];
                sum = sum + v;
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    std::putint(sum);
    std::putch(10);

    let corner:i32;
    corner = cube[1][2][3];
    std::putint(corner);
    std::putch(10);

    return 0;
}
