use std;

fn main() -> i32
{
    let mat: [[i32; 3]; 2];
    let i:i32;
    let j:i32;

    mat[0][0] = 10;
    mat[0][1] = 20;
    mat[0][2] = 30;
    mat[1][0] = 40;
    mat[1][1] = 50;
    mat[1][2] = 60;

    i = 0;
    while i < 2
    {
        j = 0;
        while j < 3
        {
            let v:i32;
            v = mat[i][j];
            std::putint(v);
            std::putch(32);
            j = j + 1;
        }
        std::putch(10);
        i = i + 1;
    }

    let sum:i32;
    sum = 0;
    i = 0;
    while i < 2
    {
        j = 0;
        while j < 3
        {
            let v:i32;
            v = mat[i][j];
            sum = sum + v;
            j = j + 1;
        }
        i = i + 1;
    }
    std::putint(sum);
    std::putch(10);

    return 0;
}
