use std;

fn main() -> i32
{
    let mat: [[i32; 4]; 3];
    let i:i32;
    let j:i32;

    i = 0;
    while i < 3
    {
        j = 0;
        while j < 4
        {
            mat[i][j] = i * 4 + j;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while i < 3
    {
        j = 0;
        while j < 4
        {
            let v:i32;
            v = mat[i][j];
            std::putint(v);
            std::putch(32);
            j = j + 1;
        }
        std::putch(10);
        i = i + 1;
    }

    return 0;
}
