use std;

fn main() -> i32 {
    let a:f32 = 3.14;
    let b:f32 = 2.71;
    let c:f32 = 3.14;

    // a > b => 1
    if a > b {
        std::putint(1);
    } else {
        std::putint(0);
    }
    std::putch(10);

    // a == c => 1
    if a == c {
        std::putint(1);
    } else {
        std::putint(0);
    }
    std::putch(10);

    // b >= a => 0
    if b >= a {
        std::putint(1);
    } else {
        std::putint(0);
    }
    std::putch(10);

    // a != b => 1
    if a != b {
        std::putint(1);
    } else {
        std::putint(0);
    }
    std::putch(10);

    // b < a => 1
    if b < a {
        std::putint(1);
    } else {
        std::putint(0);
    }
    std::putch(10);

    return 0;
}
