use std;

fn main() -> i32
{
    let a: [[i32; 3]; 3];
    let b: [[i32; 3]; 3];
    let c: [[i32; 3]; 3];
    let i:i32;
    let j:i32;
    let k:i32;

    i = 0;
    while i < 3
    {
        j = 0;
        while j < 3
        {
            a[i][j] = i * 3 + j + 1;
            b[i][j] = i * 3 + j + 1;
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while i < 3
    {
        j = 0;
        while j < 3
        {
            c[i][j] = 0;
            k = 0;
            while k < 3
            {
                let prod:i32;
                let av:i32;
                let bv:i32;
                let old:i32;
                av = a[i][k];
                bv = b[k][j];
                prod = av * bv;
                old = c[i][j];
                c[i][j] = old + prod;
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    i = 0;
    while i < 3
    {
        j = 0;
        while j < 3
        {
            let v:i32;
            v = c[i][j];
            std::putint(v);
            std::putch(32);
            j = j + 1;
        }
        std::putch(10);
        i = i + 1;
    }

    return 0;
}
