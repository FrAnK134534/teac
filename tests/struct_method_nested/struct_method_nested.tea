use std;

struct Vec2 {
    x: i32,
    y: i32
}

impl Vec2 {
    fn len1(&self) -> i32 {
        return self.x + self.y;
    }

    fn add(&mut self, dx: i32, dy: i32) -> i32 {
        self.x = self.x + dx;
        self.y = self.y + dy;
        return self.len1();
    }
}

struct Body {
    pos: Vec2,
    vel: Vec2
}

impl Body {
    fn step(&mut self, t: i32) -> i32 {
        self.pos.x = self.pos.x + self.vel.x * t;
        self.pos.y = self.pos.y + self.vel.y * t;
        return self.pos.len1();
    }

    fn energy(&self) -> i32 {
        return self.pos.len1() + self.vel.len1();
    }
}

let b: [Body; 1];

fn main() -> i32 {
    b[0].pos.x = 1;
    b[0].pos.y = 2;
    b[0].vel.x = 3;
    b[0].vel.y = 4;

    std::putint(b[0].step(2));
    std::putch(10);
    std::putint(Body::energy(b[0]));
    std::putch(10);
    b[0].vel.add(1, -1);
    std::putint(b[0].energy());
    std::putch(10);

    return b[0].pos.x + b[0].vel.y;
}
